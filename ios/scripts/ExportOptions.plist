<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Store distribution (the path TestFlight rides on).
         Use "ad-hoc" instead if you ever need to share an .ipa
         directly to a device list — not what we're doing here. -->
    <key>method</key>
    <string>app-store</string>

    <key>teamID</key>
    <string>TMBPRHZYW2</string>

    <!-- Manual signing matches our archive config: we created the
         "Mercurius App Store" Distribution profile via the App Store
         Connect API (see scripts/provision.sh) and pinned it in
         project.yml. Telling export to reuse that exact profile
         avoids the "Cloud signing permission error" Xcode throws
         when it tries to (re)create a profile during export. -->
    <key>signingStyle</key>
    <string>manual</string>
    <key>signingCertificate</key>
    <string>Apple Distribution</string>
    <key>provisioningProfiles</key>
    <dict>
        <key>com.mayoailiteracy.mercurius.native</key>
        <string>Mercurius App Store</string>
    </dict>

    <!-- Strip Swift symbols / bitcode-free dSYMs for a smaller upload.
         Apple recommends this for App Store distribution. -->
    <key>stripSwiftSymbols</key>
    <true/>

    <!-- Disable Bitcode (deprecated on iOS 17+; including would just
         bloat the upload). -->
    <key>compileBitcode</key>
    <false/>

    <!-- Include the dSYM archive so App Store Connect can symbolicate
         crashes. -->
    <key>uploadSymbols</key>
    <true/>

    <!-- "export" writes the .ipa to disk. "upload" goes direct to
         App Store Connect but needs API key configuration — leaving
         this on "export" so the first TestFlight upload uses the
         Xcode Organizer GUI for clarity. Flip to "upload" later
         once a CI runner is set up. -->
    <key>destination</key>
    <string>export</string>
</dict>
</plist>
